@model SeeSharpReviews.Models.Review

@{
    ViewData["Title"] = "Edit Review";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <h1>Edit Your Review</h1>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger" role="alert">
                    <strong>Please fix the following errors:</strong>
                    <ul class="mb-0 mt-2">
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            }

            <div class="card mb-4">
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-3">
                            @if (!string.IsNullOrEmpty(Model.MoviePosterPath))
                            {
                                <img src="https://image.tmdb.org/t/p/w200@(Model.MoviePosterPath)" 
                                     alt="@Model.MovieTitle" class="img-fluid rounded">
                            }
                        </div>
                        <div class="col-md-9">
                            <h3>@Model.MovieTitle</h3>
                            <p class="text-muted">
                                Written on <strong>@Model.CreatedAt.ToString("MMMM dd, yyyy")</strong>
                                @if (Model.UpdatedAt != Model.CreatedAt)
                                {
                                    <br />
                                    <small>Last edited: @Model.UpdatedAt.ToString("MMMM dd, yyyy")</small>
                                }
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <form method="post" asp-action="Edit" asp-route-id="@Model.ReviewId">
                @Html.HiddenFor(m => m.ReviewId)

                <div class="mb-3">
                    <label for="rating" class="form-label">Rating</label>
                    <select asp-for="Rating" class="form-select" required>
                        <option value="5" selected="@(Model.Rating == 5)">&#9733;&#9733;&#9733;&#9733;&#9733; - Excellent</option>
                        <option value="4" selected="@(Model.Rating == 4)">&#9733;&#9733;&#9733;&#9733; - Great</option>
                        <option value="3" selected="@(Model.Rating == 3)">&#9733;&#9733;&#9733; - Good</option>
                        <option value="2" selected="@(Model.Rating == 2)">&#9733;&#9733; - Fair</option>
                        <option value="1" selected="@(Model.Rating == 1)">&#9733; - Poor</option>
                    </select>
                    <span asp-validation-for="Rating" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label for="reviewText" class="form-label">Your Review</label>
                    <textarea asp-for="ReviewText" class="form-control" rows="6" required></textarea>
                    <small class="text-muted">Maximum 1000 characters</small>
                    <span asp-validation-for="ReviewText" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary w-100">Update Review</button>
                    </div>
                    <div class="col-md-4">
                        <a href="javascript:history.back()" class="btn btn-secondary w-100">Cancel</a>
                    </div>
                    <div class="col-md-4">
                        <a href="@Url.Action("Delete", new { id = Model.ReviewId })" class="btn btn-danger w-100">Delete</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
