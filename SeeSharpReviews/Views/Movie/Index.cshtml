@model MovieIndexViewModel

@{
    ViewData["Title"] = "Movies";
}

<h1 class="mb-3">Browse movies</h1>
<p class="text-muted mb-4">Search by title, or filter by genre and release year (TMDb).</p>

@if (Model.ApiKeyMissing)
{
    <div class="alert alert-warning">
        TMDb API key is not configured. Add <code>TMDb:ApiKey</code> in <code>appsettings.json</code> or user secrets (see <code>appsettings.Development.json.example</code>).
    </div>
}
else
{
    <form method="get" asp-action="Index" class="row g-3 align-items-end mb-4">
        <div class="col-md-4">
            <label class="form-label" for="q">Search</label>
            <input type="search" class="form-control" id="q" name="q" value="@Model.Query" placeholder="Title…" />
        </div>
        <div class="col-md-3">
            <label class="form-label" for="genreId">Genre</label>
            <select class="form-select" id="genreId" name="genreId">
                <option value="">Any</option>
                @foreach (var g in Model.Genres)
                {
                    if (Model.GenreId == g.Id)
                    {
                        <option value="@g.Id" selected>@g.Name</option>
                    }
                    else
                    {
                        <option value="@g.Id">@g.Name</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label" for="year">Year</label>
            <input type="number" class="form-control" id="year" name="year" value="@Model.Year"
                   placeholder="e.g. 2024" min="1900" max="2100" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary">Apply</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </form>
    <p class="small text-muted mb-3">When you enter a search term, results come from title search. Leave search empty to browse popular titles with optional genre and year filters.</p>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-info">@Model.ErrorMessage</div>
    }

    @if (Model.Results.Count > 0)
    {
        <div class="row">
            @foreach (var m in Model.Results)
            {
                <div class="col-sm-6 col-lg-4 col-xl-3 mb-4">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(m.PosterPath))
                        {
                            <img src="https://image.tmdb.org/t/p/w342@(m.PosterPath)" class="card-img-top" alt="@m.Title" />
                        }
                        else
                        {
                            <div class="card-img-top bg-light text-muted d-flex align-items-center justify-content-center" style="height: 200px;">No poster</div>
                        }
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@m.Title</h5>
                            @if (!string.IsNullOrEmpty(m.ReleaseDate))
                            {
                                <small class="text-muted">@m.ReleaseDate.Substring(0, Math.Min(4, m.ReleaseDate.Length))</small>
                            }
                            <p class="card-text small text-truncate flex-grow-1" title="@m.Overview">@m.Overview</p>
                            <a asp-action="Details" asp-route-id="@m.Id" class="btn btn-outline-primary btn-sm mt-auto">Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
